# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/nexuspartners

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RECRUITER_JWT_EXPIRES_IN=12h

# App URLs
CLIENT_URL=http://localhost:5173
# Production MUST set this to the public web app URL, e.g. https://nexuspartners.co.in
SERVER_URL=http://localhost:5000
PORT=5000
# Swagger UI (recruiter API docs): {SERVER_URL}/api/docs/recruiter
# OpenAPI JSON export: {SERVER_URL}/api/docs/recruiter/openapi.json

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@nexuspartners.com

# Gemini (Fix Resume / parse) — from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-3.1-flash-lite)
GEMINI_MODEL=gemini-3.1-flash-lite

PLACEMENT_DELETE_PASSWORD=Saibaba@2026
SALARIES_PASSWORD=Saibaba@2026

# TheirStack Job Scrap
THEIRSTACK_API_KEY=

# Razorpay (Phase 5+)
RAZORPAY_KEY_ID=mock_key_id
RAZORPAY_KEY_SECRET=mock_key_secret
RAZORPAY_WEBHOOK_SECRET=

# External student API — leave empty; students are stored in local MongoDB
NEXUS_STUDENT_API_BASE=
NEXUS_RESUME_PARSE_URL=

# External ticket API (Phase 2+)
EXTERNAL_API_SECRET=change-me-external-secret
